# =============================================================================
# CERBERUS V3.2 — COMPLETE .env REFERENCE
# =============================================================================

# -----------------------------------------------------------------------------
# API CREDENTIALS
# -----------------------------------------------------------------------------
POLYMARKET_API_KEY=your_api_key
POLYMARKET_API_SECRET=your_api_secret
POLYMARKET_API_PASSPHRASE=your_api_passphrase
POLYMARKET_WALLET_PRIVATE_KEY=your_eth_private_key
BINANCE_WS_URL=wss://stream.binance.com:9443/ws
RTDS_WS_URL=wss://ws-live-data.polymarket.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# -----------------------------------------------------------------------------
# ASSET ENABLE/DISABLE (Micro Live)
# -----------------------------------------------------------------------------
ENABLE_BTC_5M=true
ENABLE_BTC_15M=false
ENABLE_BTC_1H=false
ENABLE_ETH_5M=false
ENABLE_ETH_15M=false
ENABLE_ETH_1H=false
DRY_RUN=true

# -----------------------------------------------------------------------------
# 6-LAYER SANITIZER (Dynamic WebSocket Multiplexing)
# -----------------------------------------------------------------------------
SANITIZER_PARALLEL_CONNECTIONS=150
SANITIZER_PRUNE_INTERVAL_SECONDS=4
SANITIZER_PRUNE_PERCENT=10
SANITIZER_STAGGER_SPREAD_MS=1000
SANITIZER_WARMUP_SECONDS=15
SANITIZER_MIN_TICKS_PER_TOKEN=3
SANITIZER_MAX_JUMP_DOLLAR=15.0
SANITIZER_STALE_THRESHOLD_DOLLAR=15.0
SANITIZER_GRACE_PERIOD_SECONDS=8
SANITIZER_MAX_KILLS_PER_MINUTE=20
SANITIZER_MAX_KILLS_PER_CYCLE=2
SANITIZER_JITTER_EMA_ALPHA=0.2

# -----------------------------------------------------------------------------
# MARKET IDENTIFIERS (Override / Discovery)
# -----------------------------------------------------------------------------
# Confirmed slug patterns from live Polymarket (2026-05-29):
# 5M/15M = epoch-timestamp based, 1H = date-based
# Discovery is automatic — only override if slug format changes
BTC_5M_MARKET_SLUG=btc-updown-5m
BTC_15M_MARKET_SLUG=btc-updown-15m
BTC_1H_MARKET_SLUG=bitcoin-up-or-down
ETH_5M_MARKET_SLUG=eth-updown-5m
ETH_15M_MARKET_SLUG=eth-updown-15m
ETH_1H_MARKET_SLUG=ethereum-up-or-down

# -----------------------------------------------------------------------------
# FAIR VALUE MODEL
# -----------------------------------------------------------------------------
BTC_MODEL_PATH=data/betas_btc.npy
ETH_MODEL_PATH=data/betas_eth.npy
# Brier Thresholds:
#   WARMUP (<5000 real samples): 0.22 — looser because synthetic labels
#   have no microstructure noise (no spread, ghost fills, slippage)
#   → model looks artificially good vs live. Tighten after 7 days.
#   LIVE (>=5000 real samples): strict 0.20
MODEL_BRIER_WARMUP=0.22
MODEL_BRIER_PAUSE=0.20
MODEL_BRIER_EXCELLENT=0.15
MODEL_BRIER_ACCEPTABLE=0.20
MODEL_BRIER_WARNING=0.22
MODEL_WARNING_SIZE_MULTIPLIER=0.5
MODEL_MIN_LIVE_SAMPLES=50

# -----------------------------------------------------------------------------
# EDGE & EXECUTION THRESHOLDS (BTC 5M)
# -----------------------------------------------------------------------------
BTC_5M_MAKER_EDGE_MIN=0.025
BTC_5M_TAKER_NET_EDGE_MIN=0.030
BTC_5M_SPREAD_BASE=0.005
BTC_5M_MAX_HOLD_SECONDS=30
BTC_5M_TIME_STOP_SECONDS=10
BTC_5M_TAKER_DISABLE_SECONDS=60
BTC_5M_FORCE_FLAT_SECONDS=5
BTC_5M_POSITION_REDUCE_SECONDS=10
BTC_5M_TRADE_SIZE_USDC=2.50

# -----------------------------------------------------------------------------
# FEE-AWARE SPREAD THRESHOLD (spread_threshold.py)
# Replaces flat BTC_5M_SPREAD_BASE for dynamic fee-aware calculation.
# C_CRYPTO=0.9984 → peak taker fee ~1.56% at p=0.50
# Verify with: GET /clob/fee-config before live deployment.
# -----------------------------------------------------------------------------
# Min offset absolut — floor per market
BTC_5M_MIN_OFFSET=0.010
BTC_15M_MIN_OFFSET=0.010
BTC_1H_MIN_OFFSET=0.008
ETH_5M_MIN_OFFSET=0.012
ETH_15M_MIN_OFFSET=0.010
ETH_1H_MIN_OFFSET=0.008

# Base spread target (profit per side above fee buffer)
BTC_5M_BASE_SPREAD_TARGET=0.005
BTC_15M_BASE_SPREAD_TARGET=0.005
BTC_1H_BASE_SPREAD_TARGET=0.004
ETH_5M_BASE_SPREAD_TARGET=0.006
ETH_15M_BASE_SPREAD_TARGET=0.005
ETH_1H_BASE_SPREAD_TARGET=0.004

# (Other timeframes omitted for brevity, use identical prefix format)

# -----------------------------------------------------------------------------
# SPREAD & VOLATILITY TUNING
# -----------------------------------------------------------------------------
BTC_VOL_REFERENCE=0.02
ETH_VOL_REFERENCE=0.03
SPREAD_TIME_MULT_FINAL_60S=2.0
SPREAD_TIME_MULT_FINAL_120S=1.5
SPREAD_TIME_MULT_NORMAL=1.0

# -----------------------------------------------------------------------------
# RISK MANAGEMENT
# -----------------------------------------------------------------------------
TOTAL_CAPITAL_PUSD=200.0
DAILY_LOSS_LIMIT_USDC=5
DAILY_LOSS_LIMIT_PCT=0.05
CONSECUTIVE_LOSS_LIMIT=3
ADVERSE_SELECTION_WINDOW=10
ADVERSE_SELECTION_THRESHOLD=0.60
BTC_HOURLY_LOSS_LIMIT_USDC=150
ETH_HOURLY_LOSS_LIMIT_USDC=100
CROSS_ASSET_CORRELATION_THRESHOLD=0.80
CROSS_ASSET_SIZE_REDUCTION_PCT=0.30

# -----------------------------------------------------------------------------
# GHOSTSHIELD
# -----------------------------------------------------------------------------
GHOST_VERIFY_TIMEOUT_MS=2000
GHOST_MAX_RETRIES=3
GHOST_DECLARE_TIMEOUT_MS=5000
GHOST_PARTIAL_FILL_HANDLING=PROPORTIONAL
GHOST_RECONCILIATION_INTERVAL_S=60
GHOST_MAX_PENDING_FILLS=10
GHOST_AUTO_PAUSE_ON_SPIKE=true
GHOST_SPIKE_THRESHOLD_PCT=0.05

# -----------------------------------------------------------------------------
# ORDER MANAGEMENT
# -----------------------------------------------------------------------------
ORDER_RATE_LIMIT_COUNT=8
ORDER_RATE_LIMIT_WINDOW_S=10
ORDER_MAKER_TTL_S=3

# -----------------------------------------------------------------------------
# DATA INGESTION LIMITS
# -----------------------------------------------------------------------------
BINANCE_TICK_MAX_AGE_MS=300
POLYMARKET_BOOK_MAX_AGE_MS=500
SEQUENCE_GAP_LOG_ONLY=true

# -----------------------------------------------------------------------------
# TRAINING PIPELINE
# -----------------------------------------------------------------------------
TRAINING_DECAY_FACTOR=0.95
TRAINING_MIN_SAMPLES=5000
TRAINING_ROLLING_WINDOW_DAYS=30
TRAINING_RETRAIN_HOUR_UTC=2
TRAINING_SYNTHETIC_LABEL_WARMUP=true

# -----------------------------------------------------------------------------
# LATENCY & INFRASTRUCTURE
# -----------------------------------------------------------------------------
LATENCY_P50_TARGET_MS=110
LATENCY_P99_TARGET_MS=300
LATENCY_LOG_INTERVAL_S=60
LOG_LEVEL=INFO
LOG_FILE=logs/cerberus.log
HEARTBEAT_INTERVAL_S=10
REDIS_URL=redis://localhost:6379
PAPER_TRADING_LOG=logs/paper_trades.csv
